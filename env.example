# ================================
# RetailPulse AI — Environment Variables
# ================================
# Copy this file to .env and fill in your values.
# Never commit your actual .env file to GitHub.

# --------------------------------
# App
# --------------------------------
APP_NAME=RetailPulse AI
APP_ENV=development        # development | production
APP_PORT=3000
APP_URL=http://localhost:3000

# --------------------------------
# AI / Claude API
# --------------------------------
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
MAX_TOKENS=1000

# --------------------------------
# Database (Local Agent)
# --------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=retailpulse_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# --------------------------------
# Cloud Sync (Anonymized Insights)
# --------------------------------
CLOUD_SYNC_ENABLED=false
CLOUD_API_URL=https://api.retailpulse.ai
CLOUD_API_KEY=your_cloud_api_key_here

# --------------------------------
# Local Agent
# --------------------------------
LOCAL_AGENT_PORT=5000
LOCAL_AGENT_SYNC_INTERVAL=3600   # in seconds (default: 1 hour)
DATA_ENCRYPTION_KEY=your_encryption_key_here

# --------------------------------
# Accounting / POS Integration
# --------------------------------
POS_INTEGRATION_TYPE=generic     # generic | custom
POS_DATA_PATH=./data/transactions

# --------------------------------
# Security
# --------------------------------
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
ALLOWED_ORIGINS=http://localhost:3000
